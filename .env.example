# Supabase: banco de dados vetorial.
SUPABASE_URL=https://supabase.com/dashboard/project/xxxxxxxxxxxxxxx
SUPABASE_PROJECT_PASSWORD=xxxxxxxxxxxxxxx
SUPABASE_API_PUBLISHABLE_KEY=sb_publishable_xxxxxxx_xxxxxxx_xxxxxxx
SUPABASE_API_SECRET_KEY=sb_secret__xxxxxxxxxxxxxx_xxxx_xxxxx
SUPABASE_DB=postgresql://postgres.xxxx:xxxx@aws-1-us-west-2.pooler.supabase.com:6543/postgres

# Embeddings: query vetorizada (BAAI/bge-m3).
EMBEDDING_PROVIDER=hf or cloudflare
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CF_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CF_API_TOKEN=cfut_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# TMDb (opcional): habilita pôsteres e sinopses nos cards.
TMDB_API_KEY=xxxxxxxxxxxxxxxxxxxx.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-_xxxxxxxxx-c

# Frontend:
NEXT_PUBLIC_API_URL=http://localhost:8000
